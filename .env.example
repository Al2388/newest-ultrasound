# ============================================================
# Environment configuration template
# ============================================================
# Copy this file to .env and fill in real values.
# The .env file is gitignored and must NEVER be committed.
#
# Usage:
#   cp .env.example .env     (Linux / macOS)
#   copy .env.example .env   (Windows)
# ============================================================

# --- API Authentication ------------------------------------------
# Shared secret required on all mutating HTTP endpoints.
# Generate a strong random key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If left blank, a random key is auto-generated on each server start
# and printed to the console (only suitable for local development).
API_KEY=

# --- Box Cloud Archival (optional) -------------------------------
# Leave all BOX_* variables blank to disable cloud archival entirely.
# The system runs fully offline without these credentials.
#
# Pick ONE authentication method (JWT wins if both are set):
#
# Method A — Developer Token (60-minute expiry, good for testing)
#   Go to https://app.box.com/developers/console, open your app, and
#   click "Generate Developer Token". Paste it below.
BOX_DEV_TOKEN=
#
# Method B — JWT (server auth, no expiry, recommended for production)
#   In the Box App Console, create a "Custom App" with "Server
#   Authentication (with JWT)". Generate a key pair, download the
#   resulting JSON config, save it somewhere outside the repo, and
#   point this variable at the file path.
BOX_JWT_CONFIG=
#
# Target folder ID — paste the trailing number from a Box folder URL,
# e.g. https://app.box.com/folder/123456789012 → BOX_FOLDER_ID=123456789012
# Leave at "0" to upload into the authenticated user's root folder.
BOX_FOLDER_ID=0
